<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files and directories as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirect legacy article URLs with query params to the canonical article path.
  RewriteCond %{QUERY_STRING} (^|&)page=news_article(&|$) [NC]
  RewriteCond %{QUERY_STRING} (^|&)slug=([^&]+)(&|$) [NC]
  RewriteRule ^ /articolo/%2? [R=301,L,NE]

  # Social bot detection: redirect to Supabase Edge Function for OG meta tags.
  RewriteCond %{HTTP_USER_AGENT} (WhatsApp|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|TelegramBot|Slackbot|Discordbot|Googlebot|bingbot|Applebot|Pinterest|Snapchat) [NC]
  RewriteRule ^articolo/([^/]+)/?$ https://ncolenbfdiukkyfixovo.supabase.co/functions/v1/og-meta/$1 [R=302,L]

  # Fallback to the SPA for all app routes (including article pages for regular users).
  RewriteRule . /index.html [L]
</IfModule>

ErrorDocument 404 /404.html
