TZ=Europe/Rome
GENERIC_TIMEZONE=Europe/Rome

# URL pubblico HTTPS del tuo n8n. Se lo lanci su VPS usa direttamente il dominio;
# se lo lanci in locale esponilo con Cloudflare Tunnel o Tailscale Funnel.
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_EDITOR_BASE_URL=https://n8n.example.com/
N8N_SECURE_COOKIE=true

# Sicurezza n8n
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-a-strong-password

# Secret che Supabase usera per autenticare il webhook in ingresso
N8N_INSTAGRAM_WEBHOOK_SECRET=replace-with-a-long-random-string

# Credenziali Meta usate solo dentro n8n
INSTAGRAM_ACCESS_TOKEN=replace-with-long-lived-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=1784xxxxxxxxxxxx
