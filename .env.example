# Copia questo file come .env e inserisci le tue credenziali Supabase
# Le trovi su: https://supabase.com/dashboard → Project → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Football Data API (https://www.football-data.org/)
VITE_FOOTBALL_API_KEY=4e6fb37ef10a4c228765ee6556d78e4a

# NewsAPI.org (https://newsapi.org/) — free: 100 req/day
VITE_NEWS_API_KEY=8bf5fa0f99fd489282f4a9cdecd8bf4b

# Brevo (ex-Sendinblue) — free: 300 email/day
# Dashboard: https://app.brevo.com → Settings → API Keys
VITE_BREVO_API_KEY=your-brevo-api-key-here
VITE_BREVO_LIST_ID=2

# Newsletter sender (used by scripts/send-digest.js)
SITE_URL=https://bianconerihub.com
SENDER_EMAIL=newsletter@bianconerihub.com
SENDER_NAME=BianconeriHub

# Secret usato dal job schedulato per processare reminder match e push differite.
CRON_SECRET=replace-with-a-random-secret

# Instagram consigliato se Meta ti blocca: Buffer.
INSTAGRAM_PROVIDER=buffer
BUFFER_ACCESS_TOKEN=replace-with-buffer-access-token
BUFFER_CHANNEL_ID=replace-with-buffer-instagram-channel-id

# Alternativa diretta via Meta Graph API.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Opzionale: webhook n8n esterno. Lasciali vuoti se non vuoi usare n8n.
N8N_INSTAGRAM_WEBHOOK_URL=
N8N_INSTAGRAM_WEBHOOK_SECRET=
